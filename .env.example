# ===========================================
# CLOUDHOST - Configuración General
# ===========================================

# --- Servidor ---
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# --- Base de Datos (MongoDB) ---
MONGODB_URI=mongodb://localhost:27017/cloudhost

# --- Base de Datos (PostgreSQL - opcional) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/cloudhost

# --- JWT ---
JWT_SECRET=super-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=refresh-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# --- PayPal ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@cloudhost.com

# --- Redis (para caché y sesiones) ---
REDIS_URL=redis://localhost:6379

# --- OpenAI / IA ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4-turbo

# --- DNS (Cloudflare) ---
CLOUDFLARE_API_KEY=your-cloudflare-api-key
CLOUDFLARE_EMAIL=your-email@example.com

# --- Dominios (Namecheap / GoDaddy API) ---
NAMECHEAP_API_USER=your-namecheap-user
NAMECHEAP_API_KEY=your-namecheap-api-key
GODADDY_API_KEY=your-godaddy-api-key
GODADDY_API_SECRET=your-godaddy-api-secret

# --- Almacenamiento ---
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=cloudhost-files

# --- Docker ---
DOCKER_REGISTRY=your-registry.com
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password
